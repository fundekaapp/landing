---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* General styling for the page */
			body {
				font-family: 'Google Sans', sans-serif;
				color: #000000;
				margin: 0;
				padding: 0;
				overflow-x: hidden;
			}

			/* Hero Section */
			.hero-section {
				display: flex;
				justify-content: space-around;
				align-items: center;
				padding: 4em 2em;
				background-color: #ffffff;
				min-height: 600px; /* Adjust based on design */
			}

			.hero-content {
				max-width: 600px;
				text-align: left;
			}

			.hero-title {
				font-size: 3.5em;
				font-weight: 700;
				line-height: 1.1;
				margin-bottom: 0.5em;
			}

			.hero-title .highlight {
				color: #9584ff;
			}

			.hero-description {
				font-size: 1.1em;
				color: rgba(0, 0, 0, 0.8);
				margin-bottom: 2em;
				line-height: 1.6;
			}

			.signup-button {
				display: inline-block;
				background-color: #000000;
				color: #ffffff;
				border-radius: 24px;
				padding: 0.8em 2em;
				text-decoration: none;
				font-weight: 500;
				transition: background-color 0.3s ease;
			}

			.signup-button:hover {
				background-color: #333333;
			}

			.hero-image-container {
				position: relative;
				width: 400px; /* Adjust based on Penpot design */
				height: 400px; /* Adjust based on Penpot design */
			}

			.hero-image-container svg {
				width: 100%;
				height: auto;
			}

			.blurred-circle {
				position: absolute;
				background-color: rgba(149, 132, 255, 0.5); /* Penpot ellipse color */
				border-radius: 50%;
				filter: blur(94px); /* Penpot blur value */
				z-index: -1;
			}

			.circle-1 {
				width: 782px;
				height: 796px;
				top: -200px;
				left: -300px;
			}

			/* Section: Better learning, better results */
			.learning-results-section {
				display: flex;
				justify-content: center;
				align-items: center;
				padding: 6em 2em;
				background-color: #f8f8f8; /* A light background for contrast */
			}

			.learning-content {
				max-width: 600px;
				text-align: left;
				margin-right: 4em;
			}

			.learning-title {
				font-size: 2.8em;
				font-weight: 700;
				line-height: 1.1;
				margin-bottom: 0.5em;
			}

			.learning-title .highlight {
				color: #9584ff;
			}

			.learning-description {
				font-size: 1.1em;
				color: rgba(0, 0, 0, 0.8);
				margin-bottom: 2em;
				line-height: 1.6;
			}

			.learn-more-link {
				color: rgba(0, 0, 0, 0.8);
				text-decoration: underline;
				font-weight: 500;
			}

			.learning-image-container img {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
			}

			/* Benefits Section */
			.benefits-section {
				padding: 4em 2em;
				background-color: #ffffff;
				text-align: center;
			}

			.benefits-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2em;
				max-width: 1200px;
				margin: 0 auto;
			}

			.benefit-card {
				background-color: #8cff85; /* Penpot Rectangle colors */
				color: #ffffff;
				border-radius: 24px;
				padding: 1.5em;
				text-align: center;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				height: 200px;
			}

			.benefit-card.purple {
				background-color: #9584ff;
			}

			.benefit-card.orange {
				background-color: #ffb785;
			}

			.benefit-icon {
				width: 60px;
				height: 60px;
				margin-bottom: 1em;
			}

			.benefit-title {
				font-size: 1.2em;
				font-weight: 700;
				margin-bottom: 0.5em;
			}

			.benefit-description {
				font-size: 0.9em;
				line-height: 1.4;
			}

			/* Media Queries */
			@media (max-width: 768px) {
				.hero-section {
					flex-direction: column-reverse;
					text-align: center;
					padding: 2em 1em;
				}

				.hero-content {
					margin-bottom: 2em;
					text-align: center;
				}

				.hero-image-container {
					width: 250px;
					height: 250px;
				}

				.learning-results-section {
					flex-direction: column;
					text-align: center;
					padding: 2em 1em;
				}

				.learning-content {
					margin-right: 0;
					margin-bottom: 2em;
					text-align: center;
				}

				.learning-image-container {
					width: 100%;
				}

				.benefits-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<div class="hero-content">
					<h1 class="hero-title">
						An easier, <span class="highlight">more powerful</span> way to learn.
					</h1>
					<p class="hero-description">
						Work with a study companion that helps you focus, organise your learning, and get results you can actually see — anytime, anywhere.
					</p>
					<a href="/signup" class="signup-button">Sign up - It's free</a>
				</div>
				<div class="hero-image-container">
					<div class="blurred-circle circle-1"></div>
