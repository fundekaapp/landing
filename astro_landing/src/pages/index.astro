				</div>
			</section>

			<section class="learning-results-section">
				<div class="learning-content">
					<h2 class="learning-title">
						Better learning, better <span class="highlight">results</span>
					</h2>
					<p class="learning-description">
						Scientifically backed study methods to help you master concepts
					</p>
					<a href="/learn-more" class="learn-more-link">Learn more</a>
				</div>
				<div class="learning-image-container">
					<img src="/assets/learning-results.png" alt="Learning Results" />
				</div>
			</section>

			<section class="benefits-section">
				<div class="benefits-grid">
					<div class="benefit-card">
						<h3 class="benefit-title">AI Study Companion</h3>
						<p class="benefit-description">AI Study Companion description</p>
					</div>
					<div class="benefit-card purple">
						<h3 class="benefit-title">Spaced Repetition Flashcards</h3>
						<p class="benefit-description">Spaced Repetition Flashcards description</p>
					</div>
					<div class="benefit-card orange">
						<h3 class="benefit-title">Past Exam Question Quizzes</h3>
						<p class="benefit-description">Past Exam Question Quizzes description</p>
					</div>
					<div class="benefit-card orange">
						<h3 class="benefit-title">Built-in Exam and Study timetable</h3>
						<p class="benefit-description">Built-in Exam and Study timetable description</p>
					</div>
					<div class="benefit-card">
						<h3 class="benefit-title">Gamified Learning</h3>
						<p class="benefit-description">Gamified Learning description</p>
					</div>
					<div class="benefit-card purple">
						<h3 class="benefit-title">Video and Audio Content</h3>
						<p class="benefit-description">Video and Audio Content description</p>
					</div>
					<div class="benefit-card">
						<h3 class="benefit-title">Concept Understanding map</h3>
						<p class="benefit-description">Concept Understanding map description</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>